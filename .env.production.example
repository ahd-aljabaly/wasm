# ================================================
#  قالب إعدادات الإنتاج — انسخه إلى .env على الخادم
#  ثم عبّئ القيم الحقيقية ونفّذ: php artisan key:generate
# ================================================

APP_NAME="Wasm Media"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

# سجلّات الأخطاء
LOG_CHANNEL=stack
LOG_LEVEL=error

# -------- قاعدة البيانات --------
# الخيار 1: MySQL (موصى به للإنتاج)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wasm
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# الخيار 2: SQLite (لمواقع خفيفة) — احذف سطور MySQL أعلاه واستخدم:
# DB_CONNECTION=sqlite
# (وأنشئ الملف: touch database/database.sqlite)

# الجلسات والكاش والطوابير
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# -------- البريد الإلكتروني (مطلوب لإشعارات نموذج التواصل) --------
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_SCHEME=tls
MAIL_USERNAME=your_smtp_user
MAIL_PASSWORD=your_smtp_password
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"
# عنوان استقبال الطلبات (يمكن تغييره أيضاً من لوحة التحكم: إعدادات → notification_email)
MAIL_ADMIN_ADDRESS="info@your-domain.com"

VITE_APP_NAME="${APP_NAME}"
